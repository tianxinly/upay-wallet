{
  "name": "upay-wallet",
  "version": "1.0.5",
  "private": true,
  "description": "Enterprise TRON desktop app: offline signing + broadcast (TRC20 USDT)",
  "author": "Your Company",
  "main": "electron-dist/main.js",
  "type": "commonjs",
  "scripts": {
    "dev": "npm run build && electron .",
    "dev:hot": "cmd /c \"start \"\" tsup --watch && start \"\" vite && wait-on electron-dist/main.js http://localhost:5173 && electron .\"",
    "build:renderer": "vite build",
    "build:main": "tsup",
    "build": "npm run build:main && npm run build:renderer",
    "dist:win": "npm run build && electron-builder -w",
    "dist:mac": "npm run build && electron-builder -m",
    "dist": "npm run build && electron-builder",
    "verify:collectsign": "node scripts/verify-collect-sign.cjs",
    "verify:broadcast": "node scripts/verify-broadcast.cjs",
    "verify:scan": "node scripts/verify-scan.cjs",
    "lint": "echo \"(optional) add lint script\""
  },
  "dependencies": {
    "qrcode": "^1.5.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tronweb": "^6.0.0",
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@emnapi/core": "^1.9.2",
    "@emnapi/runtime": "^1.9.2",
    "@types/node": "^22.0.0",
    "@vitejs/plugin-react": "^6.0.1",
    "electron": "^41.2.0",
    "electron-builder": "^26.8.1",
    "png2icons": "^2.0.1",
    "sharp": "^0.34.5",
    "tsup": "^8.0.0",
    "typescript": "^5.6.0",
    "vite": "^8.0.8",
    "wait-on": "^7.2.0"
  },
  "overrides": {
    "axios": "^1.15.0",
    "lodash": "^4.17.24"
  },
  "build": {
    "appId": "com.company.upaywallet",
    "productName": "upay-wallet",
    "artifactName": "upay-wallet-${os}-${arch}.${ext}",
    "files": [
      "electron-dist/**",
      "dist/**",
      "package.json"
    ],
    "extraResources": [
      "collect-sign.sample.json",
      "broadcast.sample.json"
    ],
    "asar": true,
    "directories": {
      "buildResources": "resources",
      "output": "release"
    },
    "mac": {
      "icon": "resources/icon.icns",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "win": {
      "icon": "resources/icon.ico",
      "target": [
        "nsis",
        "zip"
      ]
    }
  }
}
